# Normalize line endings to LF in the repository
* text=auto eol=lf

# Dart / Flutter
*.dart text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.ts   text eol=lf

# Binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.ttf  binary
*.otf  binary
